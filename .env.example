# ==========================================================
# Configuración de la base de datos MySQL
# Copia este archivo a .env y ajusta los valores
# ==========================================================
MYSQL_ROOT_PASSWORD=root_super_secreto
MYSQL_DATABASE=gastos
MYSQL_USER=gastos_user
MYSQL_PASSWORD=gastos_pass

# Debe coincidir con MYSQL_PASSWORD (Compose usa MYSQL_PASSWORD para el backend).
DB_PASS=gastos_pass

# ==========================================================
# Seguridad / Autenticación
# ==========================================================
# Clave secreta para firmar los tokens JWT. CÁMBIALA por una larga y aleatoria.
JWT_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria
# Credenciales del usuario admin que se crea en el primer arranque.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin.00

# ==========================================================
# Puertos expuestos en el host
# ==========================================================
# Puerto por el que accederás a la app (frontend + API)
APP_PORT=28080
# Puerto del MySQL expuesto al host (útil para conectarte con un cliente).
# En Synology puedes cambiarlo si el 3306 ya está en uso.
DB_EXTERNAL_PORT=3307
